{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "API REST para gestionar AGFs, UEs y la movilidad.",
        "title": "Controlador AGF API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/AGF_registration": {
            "post": {
                "description": "Registra un AGF con su GNB ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "AGF"
                ],
                "summary": "Registrar un AGF",
                "parameters": [
                    {
                        "description": "AGF ID",
                        "name": "agf",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.AgfId"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/agfs": {
            "get": {
                "description": "Lista los AGFs que se han registrado",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "AGF"
                ],
                "summary": "Obtener AGFs registrados",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/definitions/api.AgfId"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/registerNewUser": {
            "post": {
                "description": "Registra un nuevo usuario (UE) y lo vincula a un AGF existente.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Usuarios"
                ],
                "summary": "Registra nuevo usuario",
                "parameters": [
                    {
                        "description": "Datos del usuario",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.RegisterNewUserPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/triggerDHCP": {
            "post": {
                "description": "Inicia el cliente DHCP en un UE con IP y destino",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DHCP"
                ],
                "summary": "Lanzar cliente DHCP",
                "parameters": [
                    {
                        "description": "IP y GNB de destino",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/triggerHandover": {
            "post": {
                "description": "Solicita el Handover de un usuario a un nuevo AGF destino",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Handover"
                ],
                "summary": "Activar Handover",
                "parameters": [
                    {
                        "description": "SUPI del usuario y GNB destino",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/user_registration": {
            "post": {
                "description": "Registra un nuevo usuario (UE) en un AGF",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Usuario"
                ],
                "summary": "Registrar un usuario",
                "parameters": [
                    {
                        "description": "Usuario a registrar",
                        "name": "user",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.User"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/users": {
            "get": {
                "description": "Lista todos los usuarios registrados",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Usuario"
                ],
                "summary": "Obtener usuarios registrados",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/definitions/api.User"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.AgfId": {
            "type": "object",
            "required": [
                "gnbId"
            ],
            "properties": {
                "gnbId": {
                    "type": "string"
                }
            }
        },
        "api.RegisterNewUserPayload": {
            "type": "object",
            "required": [
                "gnbId",
                "supi"
            ],
            "properties": {
                "gnbId": {
                    "type": "string"
                },
                "supi": {
                    "type": "string"
                }
            }
        },
        "api.User": {
            "type": "object",
            "required": [
                "gnb_id",
                "imsi",
                "supi"
            ],
            "properties": {
                "gnb_id": {
                    "type": "string"
                },
                "imsi": {
                    "type": "string"
                },
                "supi": {
                    "type": "string"
                }
            }
        }
    }
}